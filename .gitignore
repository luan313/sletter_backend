# =========================
# Backend (Python / FastAPI)
# =========================
# Arquivos compilados do Python
__pycache__/
*.py[cod]
*$py.class

# Ambientes Virtuais (Onde ficam as bibliotecas instaladas)
venv/
.venv/
env/
/lib/
/bin/

# Logs e testes do Python
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/

# =========================
# Frontend (Next.js / React)
# =========================
# Dependências do Node (Muito pesado, nunca vai pro Git)
node_modules/
.pnp
.pnp.js

# Pastas de build geradas pelo Next.js
.next/
out/
build/
dist/

# Logs de erro de gerenciadores de pacote
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

